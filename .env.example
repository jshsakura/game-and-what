# Copy to backend/.env (local dev) or pass as container env (Docker). .env is
# git-ignored and dockerignored — never commit or bake real keys into an image.
# EVERYTHING here is optional: with no keys the app still runs (cover search just
# falls back / is limited). config.py holds the authoritative defaults.

# ── Cover-search providers (optional) ─────────────────────────────────────────
# IGDB — manual cover search + auto-fill. Free keys: https://api-docs.igdb.com/
# (register a Twitch developer app).
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
# TheGamesDB — manual cover search + auto-fill. Free public key (instant, no
# approval) at https://thegamesdb.net/ — note: has a MONTHLY request quota.
TGDB_API_KEY=
# SteamGridDB — community box-art, broad coverage. Free Bearer token at
# https://www.steamgriddb.com/profile/preferences/api (log in, generate key).
STEAMGRIDDB_API_KEY=

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Korea-specific features (한글패치 toggle, 한글명 auto-resolve/gamelist, 한글명
# filter, cover-flag 'ko' default). PUBLIC image keeps this OFF; a Korean deploy
# sets it true.
GNW_KOREAN_MODE=false
# CORS origins, comma-separated. Default "*" — the app has NO built-in auth, so
# put it behind a Zero Trust layer (Cloudflare Access / Tailscale) when exposed.
# GNW_CORS_ORIGINS=*

# ── Upload limits (bytes; optional — defaults shown) ──────────────────────────
# GNW_MAX_ROM_BYTES=67108864          # 64 MB
# GNW_MAX_VIDEO_BYTES=536870912       # 512 MB
# GNW_MAX_MUSIC_BYTES=67108864        # 64 MB
# GNW_MAX_FIRMWARE_BYTES=67108864     # 64 MB
# GNW_MAX_EXTRA_BYTES=134217728       # 128 MB

# ── Docker-compose host-side (ignored by the local uvicorn dev run) ───────────
# GNW_HOST_PORT=38472          # host port mapped to the container's 8080
# GNW_DATA_PATH=./data         # host path for persistent data (DB + uploads)
# UID=1001                     # build arg: match the host owner of GNW_DATA_PATH
